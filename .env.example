# ============================================================
# RADDECORE ERP — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://raddecore.com
NEXT_PUBLIC_APP_URL=https://app.raddecore.com
NEXT_PUBLIC_DEMO_URL=https://demo.raddecore.com

# ---- Auth (NextAuth / custom JWT) ----
AUTH_SECRET=your-auth-secret-min-32-chars
JWT_EXPIRY=7d
SESSION_COOKIE_NAME=raddecore_session

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://user:password@host:5432/raddecore_prod
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — Starter
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...

# Stripe Price IDs — Pro
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# Stripe Price IDs — Enterprise
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_YEARLY=price_...

# ---- Email (Resend / SendGrid / SMTP) ----
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@raddecore.com
EMAIL_SUPPORT=support@raddecore.com
EMAIL_SALES=sales@raddecore.com

# ---- Storage (AWS S3 / Cloudflare R2) ----
S3_BUCKET_NAME=raddecore-uploads
S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Storage limits (in bytes)
STORAGE_LIMIT_STARTER=10737418240     # 10 GB
STORAGE_LIMIT_PRO=53687091200        # 50 GB
STORAGE_LIMIT_ENTERPRISE=0           # 0 = soft limit, enforced separately

# ---- Redis (for sessions / rate limiting) ----
REDIS_URL=redis://default:password@host:6379

# ---- Analytics ----
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- Error Monitoring ----
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ---- Feature Flags ----
ENABLE_RESTAURANT_MODULE=true
ENABLE_RETAIL_MODULE=true
ENABLE_MULTI_BRANCH=true
MAINTENANCE_MODE=false

# ---- Rate Limiting ----
RATE_LIMIT_AUTH_MAX=10       # Max auth attempts per window
RATE_LIMIT_AUTH_WINDOW=900   # Window in seconds (15 min)
RATE_LIMIT_API_MAX=1000
RATE_LIMIT_API_WINDOW=3600   # 1 hour

# ---- Demo Environment ----
DEMO_EMAIL=demo@raddecore.com
DEMO_PASSWORD=Demo@2025!
DEMO_RESET_CRON=0 0 * * *    # Reset daily at midnight UTC

# ---- Deployment ----
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
